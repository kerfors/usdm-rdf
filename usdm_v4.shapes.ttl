@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix usdm: <https://w3id.org/cdisc/usdm/v4/> .

<https://w3id.org/cdisc/usdm/v4/shapes>
    a owl:Ontology ;
    dcterms:title "CDISC USDM v4 structural SHACL shapes" ;
    dcterms:source <https://w3id.org/cdisc/usdm/v4/> ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:versionInfo "v0.6.0" .

usdm:Abbreviation-shape
    a sh:NodeShape ;
    sh:targetClass usdm:Abbreviation ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:path usdm:Abbreviation-abbreviatedText ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path usdm:Abbreviation-expandedText ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path usdm:Abbreviation-extensionAttributes ; sh:class usdm:ExtensionAttribute ] ;
    sh:property [ sh:path usdm:Abbreviation-notes ; sh:class usdm:CommentAnnotation ] .

usdm:Activity-shape
    a sh:NodeShape ;
    sh:targetClass usdm:Activity ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:path usdm:Activity-bcCategoryIds ; sh:nodeKind sh:IRI ; sh:class usdm:BiomedicalConceptCategory ] ;
    sh:property [ sh:path usdm:Activity-bcSurrogateIds ; sh:nodeKind sh:IRI ; sh:class usdm:BiomedicalConceptSurrogate ] ;
    sh:property [ sh:path usdm:Activity-biomedicalConceptIds ; sh:nodeKind sh:IRI ; sh:class usdm:BiomedicalConcept ] ;
    sh:property [ sh:path usdm:Activity-childIds ; sh:nodeKind sh:IRI ; sh:class usdm:Activity ] ;
    sh:property [ sh:path usdm:Activity-definedProcedures ; sh:class usdm:Procedure ] ;
    sh:property [ sh:path usdm:Activity-description ; sh:maxCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path usdm:Activity-extensionAttributes ; sh:class usdm:ExtensionAttribute ] ;
    sh:property [ sh:path usdm:Activity-label ; sh:maxCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path usdm:Activity-name ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path usdm:Activity-nextId ; sh:maxCount 1 ; sh:nodeKind sh:IRI ; sh:class usdm:Activity ] ;
    sh:property [ sh:path usdm:Activity-notes ; sh:class usdm:CommentAnnotation ] ;
    sh:property [ sh:path usdm:Activity-previousId ; sh:maxCount 1 ; sh:nodeKind sh:IRI ; sh:class usdm:Activity ] ;
    sh:property [ sh:path usdm:Activity-timelineId ; sh:maxCount 1 ; sh:nodeKind sh:IRI ; sh:class usdm:ScheduleTimeline ] .

