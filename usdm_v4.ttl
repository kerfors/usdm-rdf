usdm:Code-codeSystemVersion
    a owl:DatatypeProperty ;
    rdfs:label "Code-codeSystemVersion" ;
    rdfs:domain usdm:Code ;
    rdfs:range xsd:string ;
    skos:exactMatch ncit:C188868 ;
    skos:prefLabel "Code System Version" ;
    skos:definition "The version of the code system." ;
    usdm:relationshipType "Value" ;
    usdm:modelName "codeSystemVersion" ;
