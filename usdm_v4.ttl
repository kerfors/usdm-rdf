    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:ExtensionAttribute-id ; owl:cardinality "1"^^xsd:nonNegativeInteger ] ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:ExtensionAttribute-url ; owl:cardinality "1"^^xsd:nonNegativeInteger ] ;
