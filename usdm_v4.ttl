usdm:SubjectEnrollment-forStudySiteId
    a owl:ObjectProperty ;
    rdfs:label "SubjectEnrollment-forStudySiteId" ;
    rdfs:domain usdm:SubjectEnrollment ;
    rdfs:range usdm:StudySite ;
    skos:definition "A USDM relationship between the SubjectEnrollment and StudySite classes which identifies the study site to which the subject enrollment applies." ;
    usdm:relationshipType "Ref" ;
    usdm:modelName "forStudySite" ;
    usdm:modelRepresentation "Relationship" .

usdm:SubjectEnrollment-extensionAttributes
    a owl:ObjectProperty ;
