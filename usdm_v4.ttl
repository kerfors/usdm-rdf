    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:AnalysisPopulation-description ; owl:maxCardinality "1"^^xsd:nonNegativeInteger ] ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:AnalysisPopulation-instanceType ; owl:cardinality "1"^^xsd:nonNegativeInteger ] .

