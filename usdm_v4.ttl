usdm:Code-extensionAttributes
    a owl:ObjectProperty ;
    rdfs:label "Code-extensionAttributes" ;
    rdfs:domain usdm:Code ;
    rdfs:range usdm:ExtensionAttribute ;
    usdm:relationshipType "Value" .

usdm:Code-instanceType
    a owl:DatatypeProperty ;
    rdfs:label "Code-instanceType" ;
    rdfs:domain usdm:Code ;
    rdfs:range xsd:string ;
    usdm:relationshipType "Value" .

