usdm:StudyVersion-studyDesigns
    a owl:ObjectProperty ;
    rdfs:label "StudyVersion-studyDesigns" ;
    rdfs:domain usdm:StudyVersion ;
    rdfs:range usdm:StudyDesign ;
    skos:definition "A USDM relationship between the StudyVersion and StudyDesign classes which identifies the set of study designs associated with the study version." ;
    usdm:relationshipType "Value" ;
