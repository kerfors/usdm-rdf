    a owl:DatatypeProperty ;
    rdfs:label "StudyDesign-description" ;
    rdfs:domain usdm:StudyDesign ;
    rdfs:range xsd:string ;
    skos:exactMatch ncit:C215627 ;
    skos:prefLabel "Interventional Study Design Description" ;
    skos:definition "A narrative representation of the interventional study design." ;
