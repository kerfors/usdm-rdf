    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:StudyAmendmentImpact-isSubstantial ; owl:cardinality "1"^^xsd:nonNegativeInteger ] ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:StudyAmendmentImpact-type ; owl:cardinality "1"^^xsd:nonNegativeInteger ] ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:StudyAmendmentImpact-instanceType ; owl:cardinality "1"^^xsd:nonNegativeInteger ] .

usdm:StudyAmendmentImpact-id
    a owl:DatatypeProperty ;
    rdfs:label "StudyAmendmentImpact-id" ;
    rdfs:domain usdm:StudyAmendmentImpact ;
    rdfs:range xsd:string ;
    usdm:relationshipType "Value" ;
    usdm:modelName "id" ;
