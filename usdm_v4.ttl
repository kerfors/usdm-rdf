    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:CommentAnnotation-instanceType ; owl:cardinality "1"^^xsd:nonNegativeInteger ] .

usdm:CommentAnnotation-id
    a owl:DatatypeProperty ;
