usdm:StudyElement-description
    a owl:DatatypeProperty ;
    rdfs:label "StudyElement-description" ;
    rdfs:domain usdm:StudyElement ;
    rdfs:range xsd:string ;
    skos:exactMatch ncit:C188834 ;
