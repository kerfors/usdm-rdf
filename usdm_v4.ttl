    a owl:ObjectProperty ;
    rdfs:label "StudyVersion-roles" ;
    rdfs:domain usdm:StudyVersion ;
    rdfs:range usdm:StudyRole ;
    usdm:relationshipType "Value" .

usdm:StudyVersion-organizations
    a owl:ObjectProperty ;
    rdfs:label "StudyVersion-organizations" ;
    rdfs:domain usdm:StudyVersion ;
    rdfs:range usdm:Organization ;
