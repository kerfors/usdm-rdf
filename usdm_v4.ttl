# class StudyEpoch
usdm:StudyEpoch
    a owl:Class ;
    rdfs:label "StudyEpoch" ;
    skos:exactMatch ncit:C71738 ;
    skos:prefLabel "Study Epoch" ;
    skos:definition "A named time period defined in the protocol, wherein a study activity is specified and unchanging throughout the interval, to support a study-specific purpose." ;
    usdm:modifier "Concrete" ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:StudyEpoch-id ; owl:cardinality "1"^^xsd:nonNegativeInteger ] ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:StudyEpoch-name ; owl:cardinality "1"^^xsd:nonNegativeInteger ] ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:StudyEpoch-label ; owl:maxCardinality "1"^^xsd:nonNegativeInteger ] ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:StudyEpoch-description ; owl:maxCardinality "1"^^xsd:nonNegativeInteger ] ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:StudyEpoch-type ; owl:cardinality "1"^^xsd:nonNegativeInteger ] ;
