usdm:SyntaxTemplateDictionary-extensionAttributes
    a owl:ObjectProperty ;
    rdfs:label "SyntaxTemplateDictionary-extensionAttributes" ;
    rdfs:domain usdm:SyntaxTemplateDictionary ;
    rdfs:range usdm:ExtensionAttribute ;
