    usdm:modifier "Concrete" ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:AnalysisPopulation-id ; owl:cardinality "1"^^xsd:nonNegativeInteger ] ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:AnalysisPopulation-text ; owl:cardinality "1"^^xsd:nonNegativeInteger ] ;
