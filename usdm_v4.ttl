usdm:StudyElement-name
    a owl:DatatypeProperty ;
    rdfs:label "StudyElement-name" ;
    rdfs:domain usdm:StudyElement ;
    rdfs:range xsd:string ;
    skos:exactMatch ncit:C188833 ;
