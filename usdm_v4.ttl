    a owl:DatatypeProperty ;
    rdfs:label "AssignedPerson-description" ;
    rdfs:domain usdm:AssignedPerson ;
    rdfs:range xsd:string ;
    skos:exactMatch ncit:C215597 ;
    skos:prefLabel "Assigned Person Description" ;
    skos:definition "A narrative representation of the assigned person." ;
    usdm:relationshipType "Value" ;
